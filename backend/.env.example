# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Supabase PostgreSQL) ───────────────────
# Get from: Supabase → Settings → Database → Connection String → URI
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma for migrations (Session pooler or direct)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Redis (Upstash) ──────────────────────────────────
# Get from: Upstash → Your Database → Redis URL
REDIS_URL="rediss://default:[PASSWORD]@[HOST].upstash.io:6379"


# ─── JWT ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-access-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-jwt-refresh-key-change-this"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Anthropic Claude ────────────────────────────────
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ─── File Upload ─────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# ─── CORS ────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
